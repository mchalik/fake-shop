{
  "compilerOptions": {
    "target": "esnext",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "baseUrl": ".",
    "strictNullChecks": true,
    "strict": true,
    "noImplicitAny": true,
    "paths": {
      "@/app/*": ["src/1_app/*"],
      "@/pages/*": ["src/2_pages/*"],
      "@/widgets/*": ["src/3_widgets/*"],
      "@/features/*": ["src/4_features/*"],
      "@/entities/*": ["src/5_entities/*"],
      "@/shared/*": ["src/6_shared/*"],
      "@/*": ["src/*"]
    },
    "jsx": "react-jsx",
    "plugins": [{ "name": "typescript-plugin-css-modules" }]
  },
  "include": [
    "src/**/*", 
    "eslint.config.mts" // <--- Добавьте это
  ]
}